rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trips/{tripId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members.keys;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members.keys
        && (
          // The only allowed change is adding a new member (i.e. the user joining).
          request.resource.data.members.keys.hasOnly(
            resource.data.members.keys.union([request.auth.uid])
          )
          // Members can also update derived fields like `balance` and `createdAt`.
          || request.resource.data.diff(resource.data).changedKeys().hasOnly(['balance'])
        );
      allow delete: if false;

      match /entries/{entryId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members;
        allow create: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/trips/$(tripId)).data.members
          && request.resource.data.paidByUid == request.auth.uid;
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.paidByUid;
      }
    }
  }
}
